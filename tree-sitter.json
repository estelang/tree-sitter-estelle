			"injections": "queries/injections.scm"
		}
	],
	"metadata": {
		"version": "0.1.0",
		"license": "MIT",
		"description": "Tree-sitter grammar for Estelle",
		"links": {
			"repository": "https://github.com/your-org/tree-sitter-estelle"
		},
		"authors": [
			{
				"name": "t7ru",
				"email": "7@toru.ca"
			}
		]
	},
	"bindings": {
		"c": true,
		"go": false,
		"java": false,
		"kotlin": false,
		"node": false,
		"python": false,
		"rust": false,
